<!-- Contact -->
<section id="contact" class="py-5 text-light">
  <div class="container text-center">
    <h2 class="fw-bold mb-4">Contact</h2>
    <p class="lead mb-4">
      Want to get in touch? Send me a quick message below — I’ll get back to you soon.
    </p>

    <div class="row justify-content-center">
      <div class="col-lg-6">
        <form id="contact-form" action="https://formspree.io/f/mrearbok" method="POST" class="text-start">

          <div class="mb-3">
            <label class="form-label">Name</label>
            <input type="text" name="name" class="form-control" required placeholder="Your name">
          </div>

          <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" required placeholder="Your email">
          </div>

          <div class="mb-3">
            <label class="form-label">Message</label>
            <textarea name="message" class="form-control" rows="4" required placeholder="Write your message..."></textarea>
          </div>

          <input type="hidden" name="_subject" value="New message from your portfolio">
          <input type="hidden" name="_captcha" value="false">

          <div class="text-center">
            <button id="contact-submit" type="submit" class="btn btn-primary px-4">
              Send Message
            </button>
          </div>

          <div id="contact-feedback" class="alert mt-3 d-none" role="alert"></div>
        </form>

        <script>
          (function () {
            const form = document.getElementById("contact-form");
            const btn = document.getElementById("contact-submit");
            const feedback = document.getElementById("contact-feedback");

            if (!form || !btn || !feedback) return;

            const defaultBtnText = btn.textContent;

            function showFeedback(type, message) {
              feedback.classList.remove("d-none", "alert-success", "alert-danger");
              feedback.classList.add(type === "success" ? "alert-success" : "alert-danger");
              feedback.textContent = message;
            }

            form.addEventListener("submit", async function (e) {
              e.preventDefault();

              btn.disabled = true;
              btn.textContent = "Sending...";

              // Build form payload
              const formData = new FormData(form);

              try {
                const res = await fetch(form.action, {
                  method: "POST",
                  body: formData,
                  headers: { "Accept": "application/json" }
                });

                if (res.ok) {
                  form.reset();
                  showFeedback("success", "Email sent ✅ Thanks — I’ll get back to you soon.");

                  btn.textContent = "Email sent ✅";
                  setTimeout(() => {
                    btn.textContent = defaultBtnText;
                    btn.disabled = false;
                  }, 2500);
                } else {
                  showFeedback("error", "Something went wrong. Please try again.");
                  btn.textContent = defaultBtnText;
                  btn.disabled = false;
                }
              } catch (err) {
                showFeedback("error", "Network error. Please try again.");
                btn.textContent = defaultBtnText;
                btn.disabled = false;
              }
            });
          })();
        </script>

        <div id="contact-success" class="alert alert-success mt-3 d-none">
          Message sent! Thanks — I’ll get back to you soon.
        </div>

        <script>
          (function () {
            const params = new URLSearchParams(window.location.search);
            if (params.get("sent") === "1") {
              const el = document.getElementById("contact-success");
              if (el) el.classList.remove("d-none");
            }
          })();
        </script>

        <% if flash[:notice] %>
          <div class="alert alert-success mt-3"><%= flash[:notice] %></div>
        <% elsif flash[:alert] %>
          <div class="alert alert-danger mt-3"><%= flash[:alert] %></div>
        <% end %>
      </div>
    </div>

    <hr class="my-5 border-secondary">
    <div class="footer-block">

    <p class="small text-secondary mb-0">
        © <%= Time.current.year %> Ana Frescki — Built with Ruby on Rails, Docker, and Bootstrap
    </p>
    </div>
  </div>
</section>
